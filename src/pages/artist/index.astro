---
import Layout from "../../layouts/Layout.astro";
import { getAllArtists } from "@/services/musicService";
const artists = await getAllArtists();
---

<Layout title="Explorar Artistas - Music Clone Pro">
  <section class="relative h-full bg-zinc-900">
    <!-- Header Minimalista -->
    <header class="p-4 sm:p-8 pb-0">
      <h1 class="text-3xl font-bold text-white tracking-tighter capitalize">artistas</h1>
    </header>

    <main class="p-4 sm:p-8 pb-12">
      <!-- Grid de Artistas con estética Spotify (Imágenes Circulares) -->
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-x-6 gap-y-8">
        {
          artists.map((artist) => (
            <a href={`/artist/${artist.id}`} class="group flex flex-col p-4 rounded-xl bg-zinc-500/5 hover:bg-zinc-500/10 transition-all duration-300 shadow-lg">

              {/* Imagen Circular (Estándar de Spotify para artistas) */}
              <div class="relative aspect-square mb-4 shadow-[0_8px_24px_rgba(0,0,0,0.5)] overflow-hidden rounded-full">
                <img src={artist.image_url || "/default-artist.jpg"} alt={artist.name} class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-105" />

                {/* Overlay con botón de Play sutil (opcional) */}
                <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                  <div class="bg-green-500 p-3 rounded-full translate-y-2 group-hover:translate-y-0 transition-transform shadow-xl">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="black"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>
              </div>

              <div class="flex flex-col gap-1">
                <span class="text-white font-semibold capitalize tracking-tighter truncate text-base group-hover:underline group-hover:underline-offset-3">
                  {artist.name}
                </span>
                <span class="text-zinc-400 text-sm font-light tracking-tight">Artista</span>
              </div>
            </a>
          ))
        }
      </div>
      {
        artists.length === 0 && (
          <div class="flex flex-col items-center justify-center py-20 text-zinc-500">
            <p class="text-lg">Aún no hay artistas cargados en la base de datos.</p>
          </div>
        )
      }
    </main>

  </section>
</Layout>

