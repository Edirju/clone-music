---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Player from "@/components/player/Player";
import Sidebar from "@/components/Sidebar";
import { BottomNav } from "@/components/BottomNav";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-black text-white font-inter antialiased">
    <div
      id="app"
      class="relative h-screen p-0 md:p-2 gap-2 flex flex-col md:flex-row"
    >
      <!-- Sidebar: Visible desde la vista tablet y más -->
      <aside class="hidden md:flex flex-col w-87.5 overflow-y-auto">
        <Sidebar client:load />
      </aside>

      <!-- Contenedor Principal -->
      <main
        class="flex-1 rounded-none md:rounded-lg bg-zinc-900 overflow-y-auto overflow-x-hidden mb-32.5 md:mb-0 custom-scrollbar"
      >
        <slot />
      </main>

      <!-- Player y Nav Móvil -->
      <div class="fixed bottom-0 left-0 right-0 z-50 flex flex-col">
        <!-- Player persiste entre páginas -->
        <div class="px-2 pb-2 md:pb-0">
          <Player
            client:load
            transition:name="media-player"
            transition:persist
          />
        </div>
        <!-- Btn Nav: solo en mobile -->
        <div class="md:hidden">
          <BottomNav client:load />
        </div>
      </div>
    </div>
  </body>
</html>
